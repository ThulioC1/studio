
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Perfil do usuário contendo informações básicas e preferências.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "SearchHistory": {
      "title": "SearchHistory",
      "description": "Registro de uma busca realizada pelo usuário.",
      "type": "object",
      "properties": {
        "cnpj": { "type": "string" },
        "razaoSocial": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["cnpj", "razaoSocial", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/user_profiles/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Documento do perfil do usuário."
    },
    "/user_profiles/{userId}/history/{searchId}": {
      "schema": "#/backend/entities/SearchHistory",
      "description": "Histórico de buscas do usuário."
    }
  }
}
